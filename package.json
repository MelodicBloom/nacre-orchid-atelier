{
  "name": "nacre-orchid-atelier",
  "version": "0.0.0",
  "private": true,
  "description": "Living material design system — tokens, GLSL shaders, React MaterialSurface, Next.js docs atlas",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "npm run test --workspaces --if-present",
    "test:visual": "playwright test",
    "test:a11y": "npm run test:a11y --workspaces --if-present",
    "storybook": "npm run storybook --workspace=packages/components",
    "build:storybook": "npm run build:storybook --workspace=packages/components",
    "validate:types": "attw --pack packages/shaders && attw --pack packages/components",
    "generate:tokens": "node packages/tokens/scripts/generate.js",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.15.0",
    "@playwright/test": "^1.44.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
