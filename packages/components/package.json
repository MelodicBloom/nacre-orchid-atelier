{
  "name": "@nacre/components",
  "version": "0.1.0",
  "description": "Nacre Orchid Atelier — React material surface components driven by inquiry profiles, tokens, and shader presets.",
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@nacre/shaders": "*",
    "@nacre/tokens": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
