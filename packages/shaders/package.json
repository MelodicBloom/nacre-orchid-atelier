{
  "name": "@nacre/shaders",
  "version": "0.1.0",
  "description": "Nacre Orchid Atelier — inquiry-driven material shader presets. Thin-film iridescence, pearl bloom, and structural colour surfaces powered by WebGL2/1 with prefers-reduced-motion CSS fallbacks.",
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./presets/*": {
      "import": "./dist/presets/*.js",
      "types": "./dist/presets/*.d.ts"
    },
    "./fallback": {
      "import": "./dist/fallback/index.js",
      "types": "./dist/fallback/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@nacre/tokens": "*"
  },
  "devDependencies": {
    "@nacre/tokens": "*",
    "vitest": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
